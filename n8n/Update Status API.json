        "jsCode": "const { name, date, status } = $input.first().json.body;\n\nfunction getFormattedDate(dateStr) {\n    if (!dateStr) return null;\n    \n    // Normalize input to string\n    const str = String(dateStr).trim();\n\n    // Handle d/m/yy, dd/mm/yyyy etc\n    const parts = str.split(/[./-]/);\n    if (parts.length === 3) {\n        let [d, m, y] = parts;\n        if (y.length === 4) y = y.slice(-2);\n        return `${parseInt(d)}/${parseInt(m)}/${y}`;\n    }\n\n    // Handle 4-digit format \"2326\" -> \"2/3/26\"\n    if (/^\\d{4}$/.test(str)) {\n        return `${str[0]}/${str[1]}/${str.slice(2)}`;\n    }\n    \n    // Handle 6-digit format \"020326\" -> \"2/3/26\"\n    if (/^\\d{6}$/.test(str)) {\n        return `${parseInt(str.slice(0, 2))}/${parseInt(str.slice(2, 4))}/${str.slice(4)}`;\n    }\n\n    return str;\n}\n\nconst formattedDate = getFormattedDate(date);\n\n// We create an object where the key is the ACTUAL column name in the Google Sheet\n// This allows the Google Sheets node to find the column dynamically.\nconst result = {\n  \"שם\": name,\n};\n\nif (formattedDate) {\n  result[formattedDate] = status;\n}\n\nreturn result;"
