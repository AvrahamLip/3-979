            {
                "parameters": {
                    "jsCode": "// 1) Read date from path/query/body\nlet inputDate = $('Webhook').first().json.query.date;\n\n// 2) Normalize to string if it exists\nif (inputDate !== undefined && inputDate !== null) {\n    inputDate = String(inputDate).trim();\n}\n\n/**\n * Robust date formatting for various user inputs\n * Supports: \"d/m/yy\", \"dd/mm/yyyy\", \"d.m.yy\", \"2326\" (d/m/yy), \"020326\" (dd/mm/yy)\n */\nfunction getFormattedDate(dateStr) {\n    if (!dateStr) return null;\n\n    // Handle standard delimiters like \"2/3/26\" or \"02.03.2026\"\n    const parts = dateStr.split(/[./-]/);\n    if (parts.length === 3) {\n        let [d, m, y] = parts;\n        // Ensure year is 2 digits for consistency with your sheet headers\n        if (y.length === 4) y = y.slice(-2);\n        return `${parseInt(d)}/${parseInt(m)}/${y}`;\n    }\n\n    // Handle legacy 4-digit format \"2326\" -> \"2/3/26\"\n    if (/^\\d{4}$/.test(dateStr)) {\n        const d = dateStr[0];\n        const m = dateStr[1];\n        const y = dateStr.slice(2);\n        return `${d}/${m}/${y}`;\n    }\n    \n    // Handle 6-digit format \"020326\" -> \"2/3/26\"\n    if (/^\\d{6}$/.test(dateStr)) {\n        const d = parseInt(dateStr.slice(0, 2));\n        const m = parseInt(dateStr.slice(2, 4));\n        const y = dateStr.slice(4);\n        return `${d}/${m}/${y}`;\n    }\n\n    return null;\n}\n\n// 3) Parse the input or default to null\nlet parsedDate = getFormattedDate(inputDate);\n\n// 4) If no valid user date provided → fallback to today's date\nif (!parsedDate) {\n    const today = new Date();\n    const day = today.getDate();\n    const month = today.getMonth() + 1;\n    const year = String(today.getFullYear()).slice(-2);\n    parsedDate = `${day}/${month}/${year}`;\n}\n\n// 5) Use parsed date as the column key for the Google Sheet\nconst dateKey = parsedDate;\n\n// 6) Map the sheet data to the desired output format\nconst result = items.map(item => ({\n  name: item.json[\"שם\"] || \"\",\n  personalNumber: item.json[\"מספר אישי\"] || \"\",\n  department: item.json[\"מחלקה\"] || \"\",\n  role: item.json[\"תפקיד\"] || \"\",\n  todayValue: item.json[dateKey] || \"\",\n  dateUsed: dateKey\n}));\n\n// 7) Return the result for the Respond to Webhook node\nreturn [\n  {\n    json: {\n      data: result\n    }\n  }\n];\n"
